generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // En prod (Supabase) : URL via pooler PgBouncer (port 6543) pour le runtime.
  url       = env("DATABASE_URL")
  // URL directe (port 5432) pour les migrations — Prisma Migrate a besoin
  // de prepared statements que PgBouncer ne supporte pas en mode transaction.
  directUrl = env("DIRECT_URL")
}

// MVP sans auth — Entreprise est la racine. User sera ajouté plus tard.

model Entreprise {
  id            String   @id @default(cuid())
  raisonSociale String
  siret         String?
  codeNaf       String
  effectif      Int
  adresse       String
  duerps        Duerp[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Duerp {
  id                   String         @id @default(cuid())
  entrepriseId         String
  entreprise           Entreprise     @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  versions             DuerpVersion[]
  unites               UniteTravail[]
  referentielSecteurId String?
  transversesRepondues Boolean        @default(false)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
}

model DuerpVersion {
  id        String   @id @default(cuid())
  duerpId   String
  duerp     Duerp    @relation(fields: [duerpId], references: [id], onDelete: Cascade)
  numero    Int
  snapshot  Json
  pdfUrl    String?
  motif     String?
  createdAt DateTime @default(now())

  @@unique([duerpId, numero])
}

model UniteTravail {
  id                 String   @id @default(cuid())
  duerpId            String
  duerp              Duerp    @relation(fields: [duerpId], references: [id], onDelete: Cascade)
  nom                String
  description        String?
  referentielUniteId String?
  estTransverse      Boolean  @default(false)
  // Déclaration explicite « aucun risque significatif identifié »
  // lorsqu'une unité reste sans risque coché après évaluation.
  aucunRisqueJustif  String?
  risques            Risque[]
}

model Risque {
  id            String       @id @default(cuid())
  uniteId       String
  unite         UniteTravail @relation(fields: [uniteId], references: [id], onDelete: Cascade)
  referentielId String?
  libelle       String
  description   String?
  gravite       Int
  probabilite   Int
  maitrise      Int
  criticite     Int
  cotationSaisie Boolean     @default(false)
  // Critère d'appréciation recommandé par INRS ED 840 (nombre de personnes
  // exposées). Alimente aussi, le cas échéant, les annexes pénibilité / C2P.
  nombreSalariesExposes Int?
  // Date des dernières mesures physiques (bruit R. 4432, éclairement
  // R. 4223-4, ambiances thermiques, vibrations R. 4441). Optionnel — à
  // renseigner quand l'activité impose une mesure.
  dateMesuresPhysiques  DateTime?
  // Indique une exposition à un agent CMR — cancérogène, mutagène ou toxique
  // pour la reproduction (R. 4412-59 et suivants). Déclenche des obligations
  // renforcées : liste des salariés exposés, suivi médical, substitution.
  exposeCMR             Boolean    @default(false)
  mesures       Mesure[]

  @@unique([uniteId, referentielId])
}

model Mesure {
  id                  String    @id @default(cuid())
  risqueId            String
  risque              Risque    @relation(fields: [risqueId], references: [id], onDelete: Cascade)
  referentielMesureId String?
  libelle             String
  type                String
  statut              String
  echeance            DateTime?
  responsable         String?

  @@unique([risqueId, referentielMesureId])
}
